# ============================================
# CheckTrack - Complete .htaccess
# ============================================

# --- SINGLE RewriteEngine ON (must be first) ---
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # === 1. SKIP valid files/directories early ===
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # === 2. ALLOW specific valid paths (prevent redirect loop) ===
    # Login page, index, API, assets, install — let them through
    RewriteCond %{REQUEST_URI} ^/login\.php$ [NC,OR]
    RewriteCond %{REQUEST_URI} ^/index\.php$ [NC,OR]
    RewriteCond %{REQUEST_URI} ^/api/ [NC,OR]
    RewriteCond %{REQUEST_URI} ^/assets/ [NC,OR]
    RewriteCond %{REQUEST_URI} ^/install/ [NC,OR]
    RewriteCond %{REQUEST_URI} ^/lang/ [NC,OR]
    RewriteCond %{REQUEST_URI} \.(css|js|png|jpg|jpeg|gif|svg|ico|woff|woff2|ttf|eot|json)$ [NC]
    RewriteRule ^ - [L]

    # === 3. REDIRECT all invalid URLs to login ===
    # This catches: /abcd123, /wp-admin, /random, /page.php?id=../../../etc/passwd, etc.
    RewriteCond %{REQUEST_URI} !^/login\.php$ [NC]
    RewriteRule ^(.*)$ /login.php [L,R=302]

    # === 4. HTTPS FORCE (after valid request check) ===
    RewriteCond %{HTTPS} off
    RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

    # === 5. BLOCK sensitive paths → redirect to login (honeypot) ===
    RewriteCond %{REQUEST_URI} ^/(includes|\.git)/ [NC,OR]
    RewriteCond %{REQUEST_URI} (wp-admin|wp-login|phpmyadmin|adminer|xmlrpc\.php|\.env|config\.php) [NC]
    RewriteRule ^(.*)$ /login.php [L,R=302]
</IfModule>

# --- Block .env .bak .sql files ---
<FilesMatch "\.(env|bak|sql)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Deny from all
    </IfModule>
</FilesMatch>

# --- Security headers ---
<IfModule mod_headers.c>
    Header set X-Frame-Options "DENY"
    Header set X-XSS-Protection "1; mode=block"
    Header set X-Content-Type-Options "nosniff"
    Header set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# --- GZIP compression ---
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/json
</IfModule>

# --- Browser caching ---
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    ExpiresByType image/jpeg "access plus 1 month"
    ExpiresByType image/png "access plus 1 month"
    ExpiresByType image/gif "access plus 1 month"
    ExpiresByType image/svg+xml "access plus 1 month"
</IfModule>

# --- Prevent directory listing ---
Options -Indexes

# --- Hide server signature ---
ServerSignature Off
